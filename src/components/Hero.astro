---
import { SITE, STATS, SOCIALS } from "../config";
---

<section class="hero" id="top">
  <div class="container hero-inner">
    <p class="status reveal">
      <span class="dot"></span>
      Available for freelance AI-agent work
    </p>

    <h1 class="hero-title reveal">
      Building autonomous AI agents &amp; Web3 products, engineered for production.
    </h1>

    <p class="hero-lead reveal">
      I’m {SITE.name} — a full-stack engineer based in {SITE.location}. I design
      and build LLM-powered agents, local-first AI tools and crypto
      infrastructure, taking products from first prototype to production.
    </p>

    <div class="hero-actions reveal">
      <a href="#work" class="btn btn-primary">View my work</a>
      <a href="#contact" class="btn btn-ghost">Hire me</a>
    </div>

    <ul class="hero-socials reveal" aria-label="Social links">
      {
        SOCIALS.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
              <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true">
                <path fill="currentColor" d={s.icon} />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>

    <dl class="stats reveal">
      {
        STATS.map((s, i) => (
          <div class="stat">
            <dt class="stat-value">{s.value}</dt>
            <dd class="stat-label">{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(8rem, 17vh, 12rem);
    padding-bottom: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.9rem 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--text-soft);
    background: var(--bg-elev);
    margin-bottom: 2rem;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent);
    animation: pulse 2.6s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255, 94, 58, 0.5); }
    70% { box-shadow: 0 0 0 7px rgba(255, 94, 58, 0); }
    100% { box-shadow: 0 0 0 0 rgba(255, 94, 58, 0); }
  }

  .hero-title {
    font-size: clamp(2.3rem, 6.4vw, 4.4rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.035em;
    max-width: 19ch;
    overflow-wrap: break-word;
  }
  .hero-lead {
    margin-top: 1.8rem;
    max-width: 56ch;
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    color: var(--text-soft);
  }
  .hero-actions {
    margin-top: 2.4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-socials {
    display: flex;
    gap: 0.6rem;
    margin-top: 2rem;
  }
  .hero-socials a {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-soft);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .hero-socials a:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: var(--bg-elev);
  }

  .stats {
    margin-top: 3.5rem;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: clamp(1.75rem, 6vw, 4.5rem);
    justify-content: start;
    padding-top: 2.25rem;
    border-top: 1px solid var(--border);
  }
  .stat-value {
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    font-feature-settings: "tnum" 1;
  }
  .stat-value::after {
    content: "";
    display: block;
    width: 1.4rem;
    height: 2px;
    margin-top: 0.7rem;
    background: var(--accent);
  }
  .stat-label {
    margin-top: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    letter-spacing: 0.01em;
  }

  /* stagger */
  .reveal:nth-child(1) { transition-delay: 0.02s; }
  .reveal:nth-child(2) { transition-delay: 0.08s; }
  .reveal:nth-child(3) { transition-delay: 0.14s; }
  .reveal:nth-child(4) { transition-delay: 0.2s; }
  .reveal:nth-child(5) { transition-delay: 0.26s; }
  .reveal:nth-child(6) { transition-delay: 0.32s; }

  @media (max-width: 540px) {
    .stats {
      grid-template-columns: 1fr 1fr;
      gap: 1.6rem;
    }
  }
</style>
