---
import { SERVICES } from "../config";
---

<section class="section services" id="services">
  <div class="container">
    <div class="services-head reveal">
      <p class="eyebrow"><span class="eyebrow-num">03</span> Freelance services</p>
      <h2 class="section-title">How I can help your team</h2>
      <p class="section-lead">
        I take on focused engagements where AI and full-stack delivery meet —
        from proof-of-concept to production hardening. Here’s where I add the
        most value.
      </p>
    </div>

    <ul class="services-grid">
      {
        SERVICES.map((s) => (
          <li class="svc reveal">
            <span class="svc-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="24" height="24">
                <path fill="currentColor" d={s.icon} />
              </svg>
            </span>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-desc">{s.description}</p>
          </li>
        ))
      }
    </ul>

    <div class="services-cta reveal">
      <div>
        <h3>Have a project in mind?</h3>
        <p>Tell me what you’re building and I’ll map the fastest route to production.</p>
      </div>
      <a href="#contact" class="btn btn-primary">Start a project</a>
    </div>
  </div>
</section>

<style>
  .services-head {
    max-width: 640px;
    margin-bottom: 2.75rem;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .svc {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    padding: 1.75rem;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .svc:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
  }
  .svc-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius);
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid rgba(255, 94, 58, 0.22);
    margin-bottom: 1.2rem;
  }
  .svc-title {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .svc-desc {
    margin-top: 0.6rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .services-cta {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 2.25rem clamp(1.5rem, 4vw, 2.75rem);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elev);
  }
  .services-cta h3 {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .services-cta p {
    margin-top: 0.3rem;
    color: var(--text-soft);
  }

  @media (max-width: 720px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
