---
import { PROJECTS } from "../config";
---

<section class="section work" id="work">
  <div class="container">
    <div class="work-head reveal">
      <div>
        <p class="eyebrow"><span class="eyebrow-num">02</span> Selected work</p>
        <h2 class="section-title">Products &amp; open-source I’ve built</h2>
      </div>
      <a
        href="https://github.com/emretheus?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="all-link"
      >
        All repositories
        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M8 7h9v9"/>
        </svg>
      </a>
    </div>

    <ul class="work-grid">
      {
        PROJECTS.map((p, i) => (
          <li class="card reveal">
            <a href={p.href} target="_blank" rel="noopener noreferrer" class="card-link">
              <div class="card-top">
                <span class="card-idx">{String(i + 1).padStart(2, "0")}</span>
                <svg class="arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                  <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M8 7h9v9"/>
                </svg>
              </div>
              <h3 class="card-name">{p.name}</h3>
              <p class="card-tagline">{p.tagline}</p>
              <p class="card-desc">{p.description}</p>
              <ul class="card-tags">
                {p.tags.map((t) => <li>{t}</li>)}
              </ul>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .work-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.75rem;
  }
  .all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--text-soft);
    white-space: nowrap;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-strong);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .all-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card {
    background: var(--bg);
    transition: background 0.25s var(--ease);
  }
  .card:hover {
    background: var(--bg-card);
  }
  .card-link {
    display: block;
    padding: 1.9rem;
    height: 100%;
  }
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.4rem;
  }
  .card-idx {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .arrow {
    color: var(--text-dim);
    transition: color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .card:hover .arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
  .card-name {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .card-tagline {
    margin-top: 0.35rem;
    color: var(--text-soft);
    font-size: 0.95rem;
  }
  .card-desc {
    margin-top: 1rem;
    color: var(--text-dim);
    font-size: 0.94rem;
    line-height: 1.65;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.4rem;
  }
  .card-tags li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  @media (max-width: 720px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
    .work-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
