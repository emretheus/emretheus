---
const stack = [
  "TypeScript",
  "Python",
  "LLMs / RAG",
  "Multi-agent systems",
  "Model Context Protocol",
  "Ollama / local inference",
  "Node & Edge runtimes",
  "Solidity / Web3",
  "React / Astro",
  "Computer vision",
];
---

<section class="section" id="about">
  <div class="container about-grid">
    <div class="about-copy reveal">
      <p class="eyebrow"><span class="eyebrow-num">01</span> About</p>
      <h2 class="section-title">
        Where autonomous AI meets <span class="accent-text">production engineering</span>.
      </h2>
      <p class="section-lead">
        Across 70+ open-source projects I’ve built autonomous research agents,
        local-first AI assistants, developer tooling and Web3 infrastructure —
        with a consistent focus on privacy, reliability and real-world
        usefulness.
      </p>
      <p class="about-extra">
        Whether it’s a single workflow agent or an orchestrated fleet, I focus
        on the parts that make AI products dependable: evaluation, guardrails,
        retrieval quality, and an experience people trust.
      </p>
    </div>

    <aside class="about-side reveal" aria-label="Tech stack">
      <h3 class="side-title">Stack &amp; focus</h3>
      <ul class="chips">
        {stack.map((s) => <li class="chip">{s}</li>)}
      </ul>
    </aside>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .about-extra {
    margin-top: 1.25rem;
    max-width: 58ch;
    color: var(--text-dim);
  }
  .about-side {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    position: sticky;
    top: 96px;
  }
  .side-title {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-family: var(--font-mono);
    margin-bottom: 1.1rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .chip {
    font-size: 0.85rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    color: var(--text-soft);
    background: var(--bg-elev);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .chip:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-side {
      position: static;
    }
  }
</style>
