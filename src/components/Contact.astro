---
import { SITE, SOCIALS } from "../config";
---

<section class="section contact" id="contact">
  <div class="container contact-inner reveal">
    <p class="eyebrow"><span class="eyebrow-num">04</span> Contact</p>
    <h2 class="contact-title">
      Let’s build something <span class="accent-text">autonomous</span>.
    </h2>
    <p class="contact-lead">
      Open to freelance projects, contract work and collaborations. Email is
      the fastest way to reach me — I usually reply within a day.
    </p>

    <a href={`mailto:${SITE.email}`} class="email-link">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path fill="currentColor" d="M22 4H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h20a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm-.4 4.25-8.54 5.34a2 2 0 0 1-2.12 0L2.4 8.25a.75.75 0 0 1 .8-1.27L12 12.4l8.8-5.42a.75.75 0 1 1 .8 1.27Z"/>
      </svg>
      {SITE.email}
    </a>

    <ul class="contact-socials" aria-label="Elsewhere">
      {
        SOCIALS.filter((s) => s.label !== "Email").map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="currentColor" d={s.icon} />
              </svg>
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .contact {
    text-align: center;
  }
  .contact-inner {
    max-width: 640px;
    margin-inline: auto;
  }
  .contact .eyebrow {
    justify-content: center;
  }
  .contact .eyebrow::after {
    display: none;
  }
  .contact-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }
  .contact-lead {
    margin-top: 1.1rem;
    color: var(--text-soft);
    font-size: 1.08rem;
  }
  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 2rem;
    padding: 0.95rem 1.6rem;
    border-radius: 12px;
    border: 1px solid var(--border-strong);
    background: var(--bg-card);
    font-family: var(--font-mono);
    font-size: 1.02rem;
    color: var(--text);
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease),
      transform 0.2s var(--ease);
  }
  .email-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .contact-socials {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.75rem;
  }
  .contact-socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    transition: color 0.2s var(--ease);
  }
  .contact-socials a:hover {
    color: var(--accent);
  }
</style>
